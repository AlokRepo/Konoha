  {
    "number": 1,
    "title": "A Miraculous and Magical Reunion!",
    "overview": "Mirai Asahina leads an extremely ordinary life as a college student, while secretly—and magically—helping people as Maho Girl. However, one day, a giant monster appears in Tsunagi Town, where Mirai lives!",
    "air_date": "2025-01-11",
    "still": "https://image.tmdb.org/t/p/w500/c8bkwoC2gNaImC7Pw63Qpdud7GH.jpg",
    "runtime": 24,
    "vote_average": 0,
    "tmdb_id": 5710808
  },
  {
    "number": 2,
    "title": "Back to the Magic World!",
    "overview": "Mirai and Liko sense a new crisis looming after hearing Ire's cryptic words. They also meet a mysterious girl named Hisui, who seems to strikingly resemble Kotoha Hanami.",
    "air_date": "2025-01-18",
    "still": "https://image.tmdb.org/t/p/w500/ieOCDbjzYI2T73ybkt1R5F1tI2i.jpg",
    "runtime": 24,
    "vote_average": 0,
    "tmdb_id": 5887127
  },
  {
    "number": 3,
    "title": "The Magic of Time",
    "overview": "When the time Ire spoke of had finally come, Mirai saw a vision of Cure Miracle and Cure Magical fallen in a wasteland and Hisui being taken away by Ire. Mirai and Liko think this might be what happens in the future.",
    "air_date": "2025-01-26",
    "still": "https://image.tmdb.org/t/p/w500/yQDFjjAVyXINTJIX5nu2QxsQsgg.jpg",
    "runtime": 24,
    "vote_average": 0,
    "tmdb_id": 5887128
  },
  {
    "number": 4,
    "title": "Hisui's Secret",
    "overview": "Mirai and Liko resolved again to thwart Ire's devious plot and protect Hisui. They decide to track down his whereabouts using the vision Mirai saw of Ire standing in front of some bookshelves as a clue. Just then, a request comes in for the Maho Girl.",
    "air_date": "2025-02-02",
    "still": "https://image.tmdb.org/t/p/w500/cjnPK8MgPUXOLFOD0gfPiqJYRUP.jpg",
    "runtime": 24,
    "vote_average": 0,
    "tmdb_id": 5887130
  },
  {
    "number": 5,
    "title": "The Passing Years",
    "overview": "Each day, Hisui is growing more and more at an unbelievable rate. To avoid suspicion from those around them, Mirai and Liko take Hisui and move into an apartment that Liko has rented.",
    "air_date": "2025-02-09",
    "still": "https://image.tmdb.org/t/p/w500/aJdH4RZGZ7tKDYwUMZ0h8VZ075u.jpg",
    "runtime": 24,
    "vote_average": 0,
    "tmdb_id": 5887131
  },
  {
    "number": 6,
    "title": "True Objective",
    "overview": "To their astonishment, it is revealed that the ominous vision seen by Mirai, Liko, and Mofurun is set to come true the very next day. To change this future, Mirai and Liko decide to leave Hisui in the Magicless World and journey together to the Magic World.",
    "air_date": "2025-02-16",
    "still": "https://image.tmdb.org/t/p/w500/7bNqpE77sGTebYKoIEonUPAqHMl.jpg",
    "runtime": 24,
    "vote_average": 0,
    "tmdb_id": 5970052
  },
  {
    "number": 7,
    "title": "The Guardian of Time",
    "overview": "The Time Beast Chronosto has revealed its form, and its power has turned Ire to stone. What’s more, Kotoha has reverted to her old form, and Hisui has disappeared. Mirai and the others are filled with questions and look to Kotoha for answers about what happened.",
    "air_date": "2025-02-23",
    "still": "https://image.tmdb.org/t/p/w500/gE0FZUgYQbq529jcEEFqqTOjCzy.jpg",
    "runtime": 24,
    "vote_average": 0,
    "tmdb_id": 5971519
  },
  {
